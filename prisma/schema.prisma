generator client {
  provider        = "prisma-client"
  output          = "../lib/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_audit_log {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id   String   @db.Uuid
  action     String
  target_id  String?  @db.Uuid
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  profiles   profiles @relation(fields: [actor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([action], map: "idx_admin_audit_log_action")
  @@index([actor_id], map: "idx_admin_audit_log_actor_id")
  @@index([created_at(sort: Desc)], map: "idx_admin_audit_log_created_at")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model agents {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id        String       @unique @db.Uuid
  license_number    String       @unique
  agency_name       String?
  specialization    String[]
  phone             String?
  verified          Boolean?     @default(false)
  verification_date DateTime?    @db.Timestamptz(6)
  years_experience  Int?
  bio               String?
  photo_url         String?
  rating            Decimal?     @db.Decimal(3, 2)
  total_sales       Int?         @default(0)
  total_listings    Int?         @default(0)
  created_at        DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?    @default(now()) @db.Timestamptz(6)
  whatsapp          String?      @db.VarChar(20)
  profiles          profiles     @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties        properties[]

  @@index([profile_id], map: "idx_agents_profile_id")
  @@index([verified], map: "idx_agents_verified")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model inquiries {
  id                                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id                            String     @db.Uuid
  sender_id                              String     @db.Uuid
  owner_id                               String     @db.Uuid
  message                                String
  status                                 String     @default("new")
  created_at                             DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?  @default(now()) @db.Timestamptz(6)
  profiles_inquiries_owner_idToprofiles  profiles   @relation("inquiries_owner_idToprofiles", fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties                             properties @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_inquiries_sender_idToprofiles profiles   @relation("inquiries_sender_idToprofiles", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([owner_id], map: "idx_inquiries_owner_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model kyc_requests {
