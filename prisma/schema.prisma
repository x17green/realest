/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id                                      String               @id @db.Uuid
  email                                   String
  full_name                               String?
  avatar_url                              String?
  phone                                   String?
  bio                                     String?
  created_at                              DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime?            @default(now()) @db.Timestamptz(6)
  admin_audit_log                         admin_audit_log[]
  agents                                  agents?
  email_campaigns                         email_campaigns[]
  inquiries_inquiries_owner_idToprofiles  inquiries[]          @relation("inquiries_owner_idToprofiles")
  inquiries_inquiries_sender_idToprofiles inquiries[]          @relation("inquiries_sender_idToprofiles")
  kyc_requests                            kyc_requests[]
  notifications                           notifications[]
  owners                                  owners?
  payments                                payments[]
  users                                   users                @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "profiles_users_id_fkey")
  property_documents                      property_documents[]
  reviews                                 reviews[]
  saved_properties                        saved_properties[]
  referral_code                           String?              @unique @db.VarChar(20)
  referred_by                             String?              @db.Uuid
  referred_by_code                        String?              @db.VarChar(20)
  referral_count                          Int                  @default(0)
  referrer                                profiles?            @relation("ProfileReferrals", fields: [referred_by], references: [id], onDelete: SetNull)
  referrals                               profiles[]           @relation("ProfileReferrals")

  @@index([referral_code], map: "idx_profiles_referral_code")
  @@index([referred_by],   map: "idx_profiles_referred_by")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model properties {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id            String?              @db.Uuid
  title               String
  description         String?
  price               Decimal              @db.Decimal
  property_type       String
  listing_type        String               @default("'for_rent'::text")
  address             String
  city                String
  state               String?
  postal_code         String?
  country             String               @default("NG")
  latitude            Decimal?             @db.Decimal
  longitude           Decimal?             @db.Decimal
  bedrooms            Int?
  bathrooms           Decimal?             @db.Decimal
  square_feet         Decimal?             @db.Decimal
  year_built          Int?
  status              String               @default("'draft'::text")
  verification_status String               @default("pending")
  created_at          DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?            @default(now()) @db.Timestamptz(6)
  agent_id            String?              @db.Uuid
  listing_source      String?              @default("owner")
  price_frequency     String?              @default("sale")
  inquiries           inquiries[]
  payments            payments[]
  agents              agents?              @relation(fields: [agent_id], references: [id], onUpdate: NoAction)
  owners              owners?              @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property_details    property_details[]
  property_documents  property_documents[]
  property_media      property_media[]
  reviews             reviews[]
  saved_properties    saved_properties[]

  @@index([agent_id], map: "idx_properties_agent")
  @@index([description(ops: raw("gin_trgm_ops"))], map: "idx_properties_description_trgm", type: Gin)
  @@index([owner_id], map: "idx_properties_owner")
  @@index([status], map: "idx_properties_status")
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_properties_title_trgm", type: Gin)
}

