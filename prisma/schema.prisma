/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model waitlist {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String    @unique @db.VarChar(255)
  first_name               String    @db.VarChar(100)
  last_name                String?   @db.VarChar(100)
  phone                    String?   @db.VarChar(20)
  source                   String?   @default("website") @db.VarChar(50)
  status                   String?   @default("active") @db.VarChar(20)
  interests                String[]
  location_preference      String?   @db.VarChar(100)
  property_type_preference String?   @db.VarChar(50)
  budget_range             String?   @db.VarChar(50)
  subscribed_at            DateTime? @default(now()) @db.Timestamptz(6)
  unsubscribed_at          DateTime? @db.Timestamptz(6)
  last_contacted_at        DateTime? @db.Timestamptz(6)
  contact_count            Int?      @default(0)
  referrer_url             String?
  user_agent               String?
  ip_address               String?   @db.Inet
  utm_source               String?    @db.VarChar(100)
  utm_medium               String?    @db.VarChar(100)
  utm_campaign             String?    @db.VarChar(100)
  /// Auto-generated unique invite code, e.g. "A3F9B2C1"
  referral_code            String?    @unique @db.VarChar(20)
  /// UUID of the waitlist entry whose referral_code was used at signup
  referred_by              String?    @db.Uuid
  /// Cached count of successful referrals (incremented atomically)
  referral_count           Int?       @default(0)
  created_at               DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?  @default(now()) @db.Timestamptz(6)

  referrer                 waitlist?  @relation("WaitlistReferrals", fields: [referred_by], references: [id], onDelete: SetNull)
  referrals                waitlist[] @relation("WaitlistReferrals")

  @@index([email], map: "idx_waitlist_email")
  @@index([location_preference], map: "idx_waitlist_location_preference")
  @@index([referral_code], map: "idx_waitlist_referral_code")
  @@index([referred_by], map: "idx_waitlist_referred_by")
  @@index([source], map: "idx_waitlist_source")
  @@index([status], map: "idx_waitlist_status")
  @@index([subscribed_at], map: "idx_waitlist_subscribed_at")
}

/// Anonymous poll votes collected from email links (e.g. city preference polls).
model poll_responses {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Identifies the poll question, e.g. 'city'
  question_key String
  /// The selected answer, e.g. 'Lagos'
  answer       String
  /// Campaign reference tag, e.g. 'frontier' | 'milestone'
  ref          String?
  ip_address   String?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([question_key], map: "idx_poll_responses_question_key")
  @@index([answer], map: "idx_poll_responses_answer")
  @@index([created_at(sort: Desc)], map: "idx_poll_responses_created_at")
}

/// Persona-segmented launch intelligence poll catalog (form container).
model poll_forms {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String              @unique
  title       String
  description String?
  is_active   Boolean             @default(true)
  created_at  DateTime            @default(now()) @db.Timestamptz(6)
  updated_at  DateTime            @default(now()) @db.Timestamptz(6)

  questions   poll_questions[]
  submissions poll_submissions[]
}

/// Questions belonging to a poll form, keyed by segment.
model poll_questions {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id       String   @db.Uuid
  question_key  String
  segment       String
  prompt        String
  question_type String
  options       Json?
  is_required   Boolean  @default(true)
  display_order Int
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  form          poll_forms @relation(fields: [form_id], references: [id], onDelete: Cascade)

  @@unique([form_id, question_key])
  @@index([form_id, segment, display_order], map: "poll_questions_form_segment_idx")
}

/// A single respondent's poll submission (one per person per form).
model poll_submissions {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id               String                   @db.Uuid
  segment               String
  full_name             String
  email                 String
  opt_in_email_results  Boolean                  @default(false)
  referral_code         String?
  source                String                   @default("web")
  created_at            DateTime                 @default(now()) @db.Timestamptz(6)

  form                  poll_forms               @relation(fields: [form_id], references: [id], onDelete: Restrict)
  answers               poll_submission_answers[]

  @@index([form_id, segment], map: "poll_submissions_form_segment_idx")
  @@index([email], map: "poll_submissions_email_idx")
}

/// Individual answers for each question within a submission.
model poll_submission_answers {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submission_id String           @db.Uuid
  question_key  String
  answer        Json
  created_at    DateTime         @default(now()) @db.Timestamptz(6)

  submission    poll_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade)

  @@unique([submission_id, question_key])
  @@index([submission_id], map: "poll_submission_answers_submission_idx")
  @@index([question_key], map: "poll_submission_answers_question_key_idx")
}

/// Email marketing campaign records — tracks both Resend broadcast and DB-segment batch sends.
model email_campaigns {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  template_name    String
  subject          String
  /// 'resend_audience' → Resend Broadcasts API | 'db_segment' → Resend Batch API
  audience_type    String
  /// Resend audience UUID (only for resend_audience type)
  audience_id      String?
  /// JSON filter object for DB-segment queries, e.g. { "role": "owner" }
  audience_filter  Json?
  /// 'broadcast' → Resend Broadcasts API | 'batch' → Resend Batch API
  send_mode        String
  /// 'draft' | 'scheduled' | 'sending' | 'sent' | 'failed' | 'cancelled'
  status           String    @default("draft")
  /// Serialised template props used when rendering — stored so preview is reproducible
  template_props   Json?
  scheduled_at     DateTime? @db.Timestamptz(6)
  sent_at          DateTime? @db.Timestamptz(6)
  total_recipients Int?      @default(0)
  sent_count       Int?      @default(0)
  failed_count     Int?      @default(0)
  /// Resend broadcast ID or first batch message ID for reference
  resend_id        String?
  created_by       String    @db.Uuid
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  profiles         profiles  @relation(fields: [created_by], references: [id], onDelete: Restrict)

  @@index([status], map: "idx_email_campaigns_status")
  @@index([created_by], map: "idx_email_campaigns_created_by")
  @@index([created_at(sort: Desc)], map: "idx_email_campaigns_created_at")
}

enum UserRole {
  user
  agent
  owner
  admin

  @@map("user_role")
}
