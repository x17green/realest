{
  "name": "realest-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "npm run ci:filenames && eslint .",
    "ci:filenames": "node scripts/check-filenames.js",
    "lint:staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "precommit": "npm run typecheck && npm run lint",
    "start": "next start",
    "test": "echo 'no tests'",
    "setup:branches": "bash scripts/setup-branch-management.sh",
    "check:deployment": "bash scripts/check-deployment.sh",
    "switch:develop": "bash scripts/switch-branch.sh develop",
    "switch:staging": "bash scripts/switch-branch.sh staging",
    "switch:main": "bash scripts/switch-branch.sh main",
    "dev:coming-soon": "NEXT_PUBLIC_APP_MODE=coming-soon npm run dev",
    "dev:full-site": "NEXT_PUBLIC_APP_MODE=full-site npm run dev",
    "dev:demo": "NEXT_PUBLIC_APP_MODE=development npm run dev",
    "test:lockdown": "node scripts/test-route-lockdown.js",
    "email:export": "npx react-email export --dir emails/templates",
    "email:dev": "npx react-email dev --dir emails/templates --port 3001",
    "icons:generate": "node scripts/generate-png-icons.js",
    "db:seed": "npx tsx prisma/seed.ts",
    "audiences:seed": "npx tsx scripts/seed-resend-audiences.ts",
    "audiences:seed:dry": "npx tsx scripts/seed-resend-audiences.ts --dry-run"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
